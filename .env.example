BAIDU_APP_KEY=your-app-key
BAIDU_SECRET_KEY=your-secret-key
BAIDU_REDIRECT_URI=oob
BAIDU_SCOPE=basic,netdisk

# Optional. Defaults to ~/.baidu-netdisk-mcp/tokens.json
BAIDU_TOKEN_STORE=

# Optional. Defaults to ~/.baidu-netdisk-mcp/operations.jsonl
BAIDU_OPERATION_LOG=

# Optional. Defaults to ~/.baidu-netdisk-mcp/selections.json
BAIDU_SELECTION_STORE=

# Optional. Defaults to ~/.baidu-netdisk-mcp/cache
BAIDU_CACHE_ROOT=

# Optional. Custom Markdown/YAML skill directory. Defaults to ~/.baidu-netdisk-mcp/skills
BAIDU_SKILLS_DIR=

# Optional. Upload/download local file access is restricted to this root.
BAIDU_LOCAL_ROOT=C:/Users/T/Desktop/workspace/baidu

# Optional. Keep true unless you intentionally need non-/apps write paths.
BAIDU_STRICT_APP_PATHS=true

# Optional. Default is 4 MiB, which is compatible with ordinary users.
BAIDU_UPLOAD_CHUNK_SIZE_BYTES=4194304

# Optional. Per-chunk transfer retry attempts. Default is 3.
BAIDU_TRANSFER_MAX_RETRIES=3
